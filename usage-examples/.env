# App config
APP_NAME=myapp
APP_ENV=development
APP_PORT=3000
APP_DEBUG=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp_dev
DB_USER=postgres
DB_PASS="local_password"
# Connection URL without credentials (preferred for security)
# Pass DB_USER and DB_PASS separately to your database client
# WARNING: This URL contains credentials. Never log or expose DB_URL.
DB_URL=postgres://${DB_USER}:${DB_PASS}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# API
# NOTE: Never commit real API keys to version control.
# Use .env.local (gitignored) or a secrets manager in production.
API_KEY=dev_key_123
API_TIMEOUT=30
API_BASE=https://api.example.com
API_URL=${API_BASE}/v1

# Feature flags
FEATURE_NEW_UI=true
FEATURE_DARK_MODE=false

# Defaults and optionals
CACHE_TTL=${CACHE_OVERRIDE:-3600}
REGION=${AWS_REGION:-us-east-1}
NOTIFY=${SLACK_WEBHOOK:+enabled}
PRICE=$$9.99

# Multiline
CERT="-----BEGIN CERT-----
abc123
-----END CERT-----"

# Export style
export LOG_LEVEL=debug
