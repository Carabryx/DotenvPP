# Production configuration example
APP_NAME=dotenvpp-demo
APP_ENV=production
APP_PORT=8080
APP_DEBUG=false

# Database
DB_HOST=db.production.internal
DB_PORT=5432
DB_NAME="prod_database"
DB_USER='deploy_user'
DB_PASS="your_demo_password_here"

# Feature flags
FEATURE_NEW_UI=true
FEATURE_DARK_MODE=true
FEATURE_BETA_API=false

# API
API_URL=https://api.production.com/v1
API_TIMEOUT=10
LOG_LEVEL=warn
